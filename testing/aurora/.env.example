# Aurora S3 credentials (copy to .env and fill in)
AURORA_ACCESS_KEY_ID=your_access_key_here
AURORA_SECRET_ACCESS_KEY=your_secret_key_here
AURORA_BUCKET=your-bucket-name

# Aurora endpoint (default shown — change if yours differs)
AURORA_ENDPOINT=https://a-s3.aur.lu

# Optional: user metadata used by s3-tests to verify identity responses.
# If omitted, placeholder values are used (some identity-checking tests will fail).
AURORA_DISPLAY_NAME=Your Name
AURORA_USER_ID=your-user-id
AURORA_EMAIL=you@example.com

# Optional: second set of credentials for cross-user compatibility tests.
# If omitted, falls back to the main credentials (cross-user tests will fail).
AURORA_ALT_ACCESS_KEY_ID=your_alt_access_key_here
AURORA_ALT_SECRET_ACCESS_KEY=your_alt_secret_key_here
AURORA_ALT_DISPLAY_NAME=Alt User
AURORA_ALT_USER_ID=your-alt-user-id
AURORA_ALT_EMAIL=alt@example.com

# Source dataset on source.coop (used by phase1 and phase2 scripts)
SOURCE_ENDPOINT=https://data.source.coop
SOURCE_BUCKET=harvard-lil
SOURCE_PREFIX=gov-data/
